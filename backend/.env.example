# FridgeChef Backend — Environment Variables (NFR-SEC-001)
# Copy to `.env` and fill secrets locally. Never commit `.env`.

# --- Gemini (Model B 한국어 추천 이유) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_S=8.0

# --- Recommend Service (NFR-PERF-003) ---
RECOMMEND_TIMEOUT_S=10.0
TOP_K_MODEL_A=10
TOP_K_MODEL_B_PRE=10
TOP_K_MODEL_B_FINAL=3
MISSING_INGREDIENTS_MAX=5

# --- DB (architect 스캐폴드) ---
DATABASE_URL=postgresql+asyncpg://fridgechef:fridgechef@localhost:5432/fridgechef

# --- Auth (NFR-SEC-002) ---
JWT_SECRET=dev-insecure-change-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MIN=1440

# --- Email ---
FRONTEND_URL=http://localhost:3000
