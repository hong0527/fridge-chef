# ──────────────────────────────────────────────────────────────
# FridgeChef 환경변수 예시
# 실제 값은 .env 파일에 복사 후 채워서 사용 (Git 커밋 금지: .gitignore 등록됨)
# NFR-SEC-001: API 키 환경변수 격리
# ──────────────────────────────────────────────────────────────

# --- Backend ---
DATABASE_URL=postgresql+asyncpg://fridgechef:fridgechef@localhost:5432/fridgechef
REDIS_URL=redis://localhost:6379/0

# JWT (NFR-SEC-002) — 32자 이상 무작위 문자열 필수.
# 생성: openssl rand -hex 32  또는  python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MIN=1440
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Gemini (https://aistudio.google.com/app/apikey 에서 발급)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_S=8.0

# Recommend (NFR-PERF-001 ≤ 10초)
RECOMMEND_TIMEOUT_S=10.0
TOP_K_MODEL_A=10
TOP_K_MODEL_B_PRE=10
TOP_K_MODEL_B_FINAL=3
MISSING_INGREDIENTS_MAX=5

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
