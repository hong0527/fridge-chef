# ──────────────────────────────────────────────────────────────
# FridgeChef 운영 배포 환경변수 예시
# 복사: cp .env.production.example .env  →  서버의 .env 에 실제 값 채우기
# 사용: docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d
# ──────────────────────────────────────────────────────────────

# JWT — 반드시 새로 생성 (로컬값 절대 재사용 금지)
# 생성: openssl rand -hex 32
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MIN=1440

# DB / Redis (외부 서비스 URL로 교체)
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/fridgechef
REDIS_URL=redis://HOST:6379/0

# CORS / URL — 운영 도메인으로 교체
CORS_ORIGINS=https://yourdomain.com
FRONTEND_URL=https://yourdomain.com
NEXT_PUBLIC_API_URL=https://api.yourdomain.com

# SMTP (운영 메일 서비스 — SendGrid / AWS SES 등)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=

# Gemini API
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_S=8.0
RECOMMEND_TIMEOUT_S=10.0
TOP_K_MODEL_A=10
TOP_K_MODEL_B_PRE=10
TOP_K_MODEL_B_FINAL=3
MISSING_INGREDIENTS_MAX=5
