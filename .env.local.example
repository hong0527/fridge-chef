# ──────────────────────────────────────────────────────────────
# FridgeChef 로컬 개발 환경변수 예시
# 복사: cp .env.example .env  →  .env 파일에서 값 채우기 (Git 커밋 금지)
# ──────────────────────────────────────────────────────────────

# JWT (NFR-SEC-002) — 32자 이상 무작위 문자열 필수
# 생성: openssl rand -hex 32
JWT_SECRET=

# Gemini API (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=

# ── 아래는 로컬 기본값 그대로 사용 가능 ────────────────────────

JWT_ALGORITHM=HS256
JWT_EXPIRE_MIN=1440

GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_S=8.0
RECOMMEND_TIMEOUT_S=10.0
TOP_K_MODEL_A=10
TOP_K_MODEL_B_PRE=10
TOP_K_MODEL_B_FINAL=3
MISSING_INGREDIENTS_MAX=5

# 로컬: docker-compose.override.yml 이 mailpit 자동 설정
# SMTP_HOST / SMTP_PORT / SMTP_USER / SMTP_PASSWORD 불필요
